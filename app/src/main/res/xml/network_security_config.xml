<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows plain HTTP (cleartext) traffic ONLY to local development hosts.
    Production traffic must always use HTTPS.

    - 10.0.2.2          : the Android emulator's alias for the host machine's localhost
    - 10.0.3.2          : Genymotion's host alias
    - localhost         : reverse-tethered devices (adb reverse tcp:80 tcp:80)
    - cashbook_api.test : the Laravel Valet/Herd vhost (sent as the Host header)

    Add your machine's LAN IP (e.g. 192.168.x.x) here if you test on a
    physical device over Wi-Fi.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">cashbook_api.test</domain>
    </domain-config>
</network-security-config>