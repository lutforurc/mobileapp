<!--
  Dashboard stat icons — one drawn set, so the four rows read as a family:
  24dp grid, 1.8 stroke, round caps and joins, and a single filled accent mark
  where a glyph needs a focal point. Colours come from the Icon tint, so the
  paths carry a placeholder black.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Calendar body -->
    <path
        android:pathData="M5.75,5.5H18.25A2.75,2.75 0 0 1 21,8.25V18.25A2.75,2.75 0 0 1 18.25,21H5.75A2.75,2.75 0 0 1 3,18.25V8.25A2.75,2.75 0 0 1 5.75,5.5Z"
        android:strokeWidth="1.8"
        android:strokeColor="#000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Header rule -->
    <path
        android:pathData="M3,10.25H21"
        android:strokeWidth="1.8"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />

    <!-- Hangers -->
    <path
        android:pathData="M8,3V7"
        android:strokeWidth="1.8"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />
    <path
        android:pathData="M16,3V7"
        android:strokeWidth="1.8"
        android:strokeColor="#000000"
        android:strokeLineCap="round" />

    <!-- The marked day -->
    <path
        android:pathData="M12,14.25m-1.6,0a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0"
        android:fillColor="#000000" />
</vector>
