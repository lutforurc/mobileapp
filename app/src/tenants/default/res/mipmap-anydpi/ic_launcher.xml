<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icons only exist from API 26, but minSdk is 24 — so API 24/25 get
     the same logo composed by hand: the background plate with the logo inset on
     top. `anydpi` outranks the density-specific folders, so this is chosen
     ahead of any bitmap, and -v26 above outranks this on newer devices. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/ic_launcher_background" />
    <item>
        <inset
            android:drawable="@drawable/logo"
            android:inset="14%" />
    </item>
</layer-list>
