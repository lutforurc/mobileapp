<?xml version="1.0" encoding="utf-8"?>
<!-- A plain near-white plate behind the tenant's logo. Logos usually carry
     transparency and are drawn for a light background, so a flat one keeps the
     mark legible whatever shape the launcher masks the icon to. A tenant that
     wants its own colour overrides this file in its own res folder, as kbr does. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#F7F7F7" />
</shape>
